# Sanity (content backend) — fill in when the Sanity project is created.
# Until NEXT_PUBLIC_SANITY_PROJECT_ID is set, the site runs on placeholder content
# and /studio shows a setup screen.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Server-only. Read token for drafts/preview (optional for published-only reads).
SANITY_API_READ_TOKEN=
# Shared secret for the /api/revalidate webhook.
SANITY_REVALIDATE_SECRET=
# Editor token used ONLY by `npm run seed` to import placeholder content.
SANITY_API_WRITE_TOKEN=

# Public site URL (no trailing slash) — used for metadata, sitemap, robots, OG tags
NEXT_PUBLIC_SITE_URL=https://dadakansunda.id
